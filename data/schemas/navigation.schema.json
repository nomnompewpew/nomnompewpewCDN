{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cdn.jsdelivr.net/gh/nomnompewpew/nomnompewpewCDN@main/data/schemas/navigation.schema.json",
  "title": "CMS Navigation",
  "description": "Site navigation tree for the nomnompewpew CMS",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": { "$ref": "#/definitions/navItem" }
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "navItem": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "href": { "type": "string" },
        "icon": { "type": "string", "description": "CDN path or name of icon asset" },
        "external": { "type": "boolean", "default": false },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/navItem" }
        }
      }
    }
  }
}
